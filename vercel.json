{
  "version": 2,
  "builds": [
    { "src": "landing.html", "use": "@vercel/static" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/claude.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/claude", "dest": "/api/claude.js" },
    { "src": "/app", "dest": "/index.html" },
    { "src": "/", "dest": "/landing.html" }
  ]
}